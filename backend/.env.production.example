APP_ENV=production
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DATABASE
FRONTEND_URL=https://your-vercel-project.vercel.app
ALLOWED_ORIGINS=https://your-vercel-project.vercel.app
UPLOAD_DIR=/var/data/uploads
UPLOAD_SESSION_DIR=/var/data/upload_sessions
THUMBNAIL_DIR=/var/data/thumbnails
CLIP_DIR=/var/data/clips
VISION_FRAME_DIR=/var/data/vision_frames
ENABLE_EMBEDDED_WORKER=true
WORKER_POLL_INTERVAL_SECONDS=3
MAX_UPLOAD_BYTES=5368709120
MAX_CHUNK_BYTES=8388608
